# ─────────────────────────────────────────────────────────────────────────────
# Agri Digest Hub — Environment Variables Template
# Copy to .env.local for local development:
#   cp .env.example .env.local
#
# Production values are set in:
#   • Vercel Dashboard → Project → Settings → Environment Variables
#   • Convex Dashboard → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Convex (Frontend/Vite) ────────────────────────────────────────────────────
# Development: set automatically by `npx convex dev` (written to .env.local)
# Production:  your Convex production deployment URL
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Convex site URL (used for auth callbacks — same host, .convex.site suffix)
# Development:  https://your-deployment.convex.site
# Production:   https://your-production-deployment.convex.site
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site

# ── Convex CLI (local dev only) ───────────────────────────────────────────────
# Set automatically by `npx convex dev`. Do NOT set this in production.
# CONVEX_DEPLOYMENT=dev:your-deployment

# ── Convex Auth — JWT Keys (set on Convex deployment, NOT in .env files) ─────
# Run ONE of the following to configure on your Convex deployment:
#
#   Option A (recommended):
#     npm run setup:auth:env
#
#   Option B (interactive):
#     npx @convex-dev/auth
#
#   Option C (manual — copy values from `npm run setup:auth` output):
#     npx convex env set JWT_PRIVATE_KEY "..."
#     npx convex env set JWKS '...'
#     npx convex env set SITE_URL https://your-production-domain.com
#
# For production, set SITE_URL to your Vercel deployment URL.

# ── Google OAuth (optional, set in Convex Dashboard) ─────────────────────────
# AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
# AUTH_GOOGLE_SECRET=your-google-client-secret

# Enable Google sign-in on the frontend (only after setting AUTH_GOOGLE_ID/SECRET)
# VITE_ENABLE_GOOGLE_AUTH=true

# ── Email / Password Reset (optional, set in Convex Dashboard) ───────────────
# AUTH_RESEND_KEY=re_your_resend_api_key
# AUTH_EMAIL_FROM=noreply@yourdomain.com
