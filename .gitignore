# ── Environment ──────────────────────────────────────────────────────────────
# Never commit real env files — use .env.example as the template
.env
.env.*
!.env.example

# ── Build output ─────────────────────────────────────────────────────────────
dist
dist-ssr

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules

# ── Logs ─────────────────────────────────────────────────────────────────────
/logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Vite / tool caches ───────────────────────────────────────────────────────
.vite
*.local

# ── Convex generated files ───────────────────────────────────────────────────
# These are regenerated automatically by `npx convex dev` / `npx convex deploy`
convex/_generated/

# ── Editor ───────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store

# ── OS ───────────────────────────────────────────────────────────────────────
Thumbs.db
